{
	"name": "eliashaeussler/phpstan-config-test-typo3-extension",
	"require-dev": {
		"symfony/filesystem": "^6.4 || ^7.4 || ^8.0",
		"symfony/process": "^6.4 || ^7.4 || ^8.0"
	},
	"config": {
		"sort-packages": true
	},
	"scripts": {
		"test": [
			"@php src/test.php composer-missing-conflict",
			"@php src/test.php composer-missing-require",
			"@php src/test.php composer-missing-suggest",
			"@php src/test.php ext-emconf-missing-conflicts",
			"@php src/test.php ext-emconf-missing-depends",
			"@php src/test.php ext-emconf-missing-suggests"
		]
	}
}
